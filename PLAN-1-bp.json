    {
      "id": "T-01",
      "stories": ["US-001", "US-017"],
      "size": "Small",
      "status": "completed",
      "whatToDo": "Creare la definizione centralizzata dei permessi come costanti nel Domain layer. Creare l'entità Permission e la tabella di giunzione RolePermission per associare permessi ai ruoli. Aggiungere il campo MustChangePassword a ApplicationUser. Aggiungere il flag IsSystemRole a ApplicationRole.",
      "definitionOfDone": [
        { "description": "Classe statica Permissions nel Domain con tutte le 16 costanti", "completed": true },
        { "description": "Entità Permission con Id, Name, Description, Category", "completed": true },
        { "description": "Entità RolePermission (join table) con RoleId, PermissionId", "completed": true },
        { "description": "Campo MustChangePassword (bool, default false) su ApplicationUser", "completed": true },
        { "description": "Campo IsSystemRole (bool, default false) su ApplicationRole", "completed": true },
        { "description": "Configurazioni EF Core per le nuove entità", "completed": true },
        { "description": "Migration che crea le tabelle e aggiunge le nuove colonne", "completed": true },
        { "description": "Unit test per le costanti dei permessi", "completed": true },
        { "description": "Build e migration applicata con successo", "completed": true }
      ]
    },
    {
      "id": "T-02",
      "stories": ["US-001"],
      "size": "Small",
      "status": "completed",
      "dependsOn": ["T-01"],
      "whatToDo": "Creare un seeder che popola il database con i 16 permessi e i 3 ruoli di sistema (SuperAdmin, Admin, User) con le relative associazioni. Il seeder è idempotente.",
      "definitionOfDone": [
        { "description": "Seeder che crea i 16 permessi nel database", "completed": true },
        { "description": "Seeder che crea i 3 ruoli di sistema con IsSystemRole = true", "completed": true },
        { "description": "SuperAdmin ha tutti i 16 permessi assegnati", "completed": true },
        { "description": "Admin ha tutti i permessi tranne Settings.Manage e Roles.Delete", "completed": true },
        { "description": "User non ha permessi admin", "completed": true },
        { "description": "Il seeder è idempotente", "completed": true },
        { "description": "Il seeder viene eseguito all'avvio dell'applicazione", "completed": true },
        { "description": "Integration test che verifica il seeding completo", "completed": true }
      ]
    },
    {
      "id": "T-03",
      "stories": ["US-001", "US-017"],
      "size": "Medium",
      "status": "completed",
      "dependsOn": ["T-02"],
      "whatToDo": "Implementare un sistema di autorizzazione che verifica i permessi dell'utente corrente. Creare un IPermissionService che carica i permessi dell'utente (con cache), un authorization handler ASP.NET che valida le policy basate su permessi, e un attributo/policy per proteggere gli endpoint. Il SuperAdmin bypassa tutti i controlli. Implementare un ITokenBlacklistService basato su IDistributedCache per l'invalidazione immediata dei token JWT.",
      "definitionOfDone": [
        { "description": "IPermissionService con metodo GetPermissionsAsync(userId)", "completed": true },
        { "description": "Cache server-side dei permessi per utente", "completed": true },
        { "description": "PermissionAuthorizationHandler che verifica i permessi", "completed": true },
        { "description": "HasPermissionAttribute per decorare gli endpoint", "completed": true },
        { "description": "SuperAdmin bypassa tutti i controlli", "completed": true },
        { "description": "I permessi inclusi nella risposta di login", "completed": true },
        { "description": "Registrazione IDistributedCache", "completed": true },
        { "description": "ITokenBlacklistService per invalidazione token", "completed": true },
        { "description": "JwtBearerEvents.OnTokenValidated controlla la blacklist", "completed": true },
        { "description": "Unit test per handler aggiornati", "completed": true },
        { "description": "Unit test per TokenBlacklistService", "completed": true },
        { "description": "Integration test per permessi nella risposta login", "completed": true }
      ]
    },
    {
      "id": "T-04",
      "stories": ["US-001"],
      "size": "Small",
      "status": "completed",
      "dependsOn": ["T-02"],
      "whatToDo": "Creare un seeder che, al primo avvio, legge le variabili d'ambiente e crea l'utente SuperAdmin. Il seeder è idempotente. L'utente viene creato con MustChangePassword = true e il ruolo SuperAdmin assegnato.",
      "definitionOfDone": [
        { "description": "Il seeder legge le variabili d'ambiente SuperAdmin", "completed": true },
        { "description": "Se non esiste un utente con ruolo SuperAdmin, ne crea uno", "completed": true },
        { "description": "Se un SuperAdmin esiste già, l'operazione viene saltata", "completed": true },
        { "description": "Il nuovo utente ha MustChangePassword = true", "completed": true },
        { "description": "Il nuovo utente ha il ruolo SuperAdmin assegnato", "completed": true },
        { "description": "Il seeder viene eseguito all'avvio dopo il seeding dei ruoli", "completed": true },
        { "description": "Se le variabili d'ambiente non sono configurate, il seeder logga un warning", "completed": true },
        { "description": "Integration test che verifica creazione e idempotenza", "completed": true }
      ]
    },
