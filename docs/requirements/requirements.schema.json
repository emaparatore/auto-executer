{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/requirements.schema.json",
  "title": "Feature Requirements Document",
  "type": "object",
  "required": [
    "document",
    "functionalRequirements",
    "nonFunctionalRequirements",
    "userStories"
  ],
  "properties": {
    "document": {
      "type": "object",
      "required": [
        "id",
        "title",
        "sourcePath",
        "language"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^FEAT-[A-Za-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "approved",
            "implemented",
            "in_progress",
            "completed"
          ]
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "sourcePath": {
          "type": "string"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "overview": {
      "type": [
        "string",
        "null"
      ]
    },
    "currentState": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/currentStateItem"
      }
    },
    "domainContext": {
      "type": [
        "object",
        "null"
      ]
    },
    "architecturalDecisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "default": []
    },
    "functionalRequirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      },
      "default": []
    },
    "nonFunctionalRequirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      },
      "default": []
    },
    "userStories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/userStory"
      },
      "default": []
    },
    "storyDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "implementationOrder": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "outOfScope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/openQuestion"
      },
      "default": []
    },
    "rawMarkdown": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "currentStateItem": {
      "type": "object",
      "required": [
        "area",
        "status",
        "notes"
      ],
      "properties": {
        "area": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": [
        "id",
        "title",
        "decision"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "requirement": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "acceptanceCriterion": {
      "type": "object",
      "required": [
        "text",
        "checked"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "checked": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "userStory": {
      "type": "object",
      "required": [
        "id",
        "title",
        "asA",
        "iWant",
        "soThat",
        "acceptanceCriteria"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "asA": {
          "type": "string"
        },
        "iWant": {
          "type": "string"
        },
        "soThat": {
          "type": "string"
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/acceptanceCriterion"
          }
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "openQuestion": {
      "type": "object",
      "required": [
        "id",
        "question",
        "answer",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "answer": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
